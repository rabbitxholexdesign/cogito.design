# Supabase
# Supabase ダッシュボード > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# セットアップ手順
# ============================================================
# 1. このファイルを .env.local にコピー
#    cp .env.local.example .env.local
#
# 2. Supabase プロジェクトを作成
#    https://supabase.com/dashboard → New project
#
# 3. supabase/schema.sql を Supabase SQL Editor で実行
#
# 4. supabase/seed.sql を Supabase SQL Editor で実行（初期データ）
#
# 5. Supabase Authentication でメールアドレスのユーザーを作成
#    ダッシュボード > Authentication > Users > Add user
#    ※ これが管理画面のログイン情報になります
#
# 6. Vercel デプロイ時は上記 3 つの環境変数を
#    Vercel ダッシュボード > Settings > Environment Variables に追加
